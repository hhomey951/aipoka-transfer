# Release binaries: distributed via GitHub Releases, not the repo
release-package/windows/*.exe
release-package/android/*.apk
release-package/playstore/*.aab
release-package/server-cli/node_modules/

# OS noise
Thumbs.db
.DS_Store

# Local Claude Code settings
.claude/settings.local.json

# Android app source kept private (Play Store distribution only)
android-app/
