{
  "name": "aipoka-desktop",
  "version": "1.0.0",
  "description": "Aipoka Photo Transfer desktop app",
  "main": "main.js",
  "author": "aipoka",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "multer": "^2.2.0",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aipoka.desktop",
    "productName": "Aipoka Transfer",
    "icon": "build/icon.png",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "lib/**/*",
      "routes/**/*"
    ]
  }
}
